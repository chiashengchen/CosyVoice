# ══════════════════════════════════════════════════════════════════════════════
# Multi-stage 示範版（教學用，正式版仍是 Dockerfile.tts）
#
# 概念：兩個 FROM = 兩個獨立的 image。第一個（builder）帶編譯器，負責「製造」；
# 第二個（最終 image）只帶執行環境，用 COPY --from=builder 把「成品」搬過來。
# 編譯器、headers、build 暫存全部留在 builder — 它 build 完就被丟棄，
# 不佔最終 image 一個 byte。
#
# 我們的例子裡「需要編譯」的東西：
#   - pyworld（C++ extension，要 g++ + numpy headers）
#   - pynini 有 manylinux wheel 所以其實不用編，但放 builder 統一處理
#   - 其他 99% 的套件都是 wheel（預編二進位），裝在哪都一樣
#
# 省多少：runtime base 比 devel/建置環境省 ~3-4GB；build-essential + python3.10-dev
# + pip 編譯暫存不進最終 image，實測可再省 ~500MB-1GB。
# ══════════════════════════════════════════════════════════════════════════════

# ── Stage 1: builder — 有編譯器的「工廠」────────────────────────────────────────
# 命名 stage（AS builder）讓第二個 stage 可以用名字引用它。
FROM nvidia/cuda:12.1.1-cudnn8-devel-ubuntu22.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.10 python3.10-dev python3-pip git build-essential \
    && rm -rf /var/lib/apt/lists/*
RUN update-alternatives --install /usr/bin/python python /usr/bin/python3.10 1 \
    && update-alternatives --install /usr/bin/pip pip /usr/bin/pip3 1

WORKDIR /build

# 把「所有 pip 安裝」都做在 builder 裡，裝進一個固定目錄（--prefix），
# 這個目錄就是待會要整包搬走的「成品」。
# （另一種常見做法是 python venv，原理相同：讓成品有明確的邊界。）
COPY requirements_inference.txt .
RUN pip install --no-cache-dir --prefix=/install "setuptools<72" \
    && pip install --no-cache-dir --prefix=/install numpy==1.26.4 pynini==2.1.5 \
    && PYTHONPATH=/install/lib/python3.10/site-packages \
       pip install --no-cache-dir --prefix=/install --no-build-isolation \
       -r requirements_inference.txt \
    && pip install --no-cache-dir --prefix=/install --no-deps openai-whisper==20231117 \
       ffmpeg-python tiktoken more-itertools \
    && pip install --no-cache-dir --prefix=/install \
       "matcha-tts @ git+https://github.com/shivammehta25/Matcha-TTS.git@dd9105b34bf2be2230f4aa1e4769fb586a3c824e" \
    && pip install --no-cache-dir --prefix=/install "vllm==0.9.2" "transformers==4.51.3" \
    && pip install --no-cache-dir --prefix=/install -U "onnxruntime-gpu==1.20.1" pyarrow cython \
    && PYTHONPATH=/install/lib/python3.10/site-packages \
       pip install --no-cache-dir --prefix=/install --force-reinstall --no-build-isolation \
       --no-binary pyworld pyworld==0.3.4 \
    && pip install --no-cache-dir --prefix=/install opencc-python-reimplemented

# ── Stage 2: 最終 image — 只有執行環境的「店面」────────────────────────────────
# 注意：base 換回 runtime（沒有編譯器），這行開始是全新的空 image。
FROM nvidia/cuda:12.1.1-cudnn8-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV LANG=C.UTF-8

# 只裝「執行期」需要的系統套件：沒有 build-essential、沒有 python3.10-dev。
# git 也不用了 — matcha 已經在 builder 裝好。ffmpeg/sox 是執行期音訊處理要的，留著。
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.10 python3-pip ffmpeg sox curl \
    && rm -rf /var/lib/apt/lists/* \
    && update-alternatives --install /usr/bin/python python /usr/bin/python3.10 1

# ★ 多階段的核心一行：把 builder 的成品目錄整包搬過來。
# /install 的內容展開到 /usr/local（site-packages、bin/ 等），
# 編譯過程的一切（.o 檔、原始碼、g++）都不會跟過來。
COPY --from=builder /install /usr/local

WORKDIR /app
ENV PYTHONPATH="/app:/app/third_party/Matcha-TTS"

# 程式碼仍然最後才進來（單階段學到的層序原則在這裡照樣適用）
COPY . .

ENV COSYVOICE_MODEL_DIR=/app/pretrained_models/CosyVoice2-0.5B
ENV HF_MODEL_ID=FunAudioLLM/CosyVoice2-0.5B
ENV USE_VLLM=0
ENV PORT=8001

VOLUME ["/app/pretrained_models"]
EXPOSE 8001
CMD ["python", "tts_stream_server.py"]
