# CosyVoice2 TTS streaming server — minimal inference image
#
# Single-stage build using runtime CUDA base + pip only (no conda, no build tools in final image).
# pynini 2.1.5 has pre-built manylinux wheels on PyPI — no conda needed.
#
# Weights are NOT baked in — downloaded from HuggingFace at first startup.
# Mount a volume at /app/pretrained_models to cache across restarts.

FROM nvidia/cuda:12.1.1-cudnn8-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV LANG=C.UTF-8

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.10 python3.10-dev python3-pip \
    git ffmpeg sox libsox-dev build-essential curl \
    && rm -rf /var/lib/apt/lists/*

# Make python3.10 the default python
RUN update-alternatives --install /usr/bin/python python /usr/bin/python3.10 1 \
    && update-alternatives --install /usr/bin/pip pip /usr/bin/pip3 1

WORKDIR /app
COPY . .

ENV PYTHONPATH="/app:/app/third_party/Matcha-TTS"

# Install Matcha-TTS from pinned submodule commit (provides 'matcha' package)
RUN pip install --no-cache-dir \
    "matcha-tts @ git+https://github.com/shivammehta25/Matcha-TTS.git@dd9105b34bf2be2230f4aa1e4769fb586a3c824e"

# Install inference deps
# - numpy first: pyworld's setup.py imports it during metadata generation
# - pynini 2.1.5 has manylinux wheels on PyPI — no conda needed
# - setuptools<72 keeps pkg_resources for old-style setup.py packages
RUN pip install --no-cache-dir "setuptools<72" \
    && pip install --no-cache-dir numpy==1.26.4 pynini==2.1.5 \
    && pip install --no-cache-dir --no-build-isolation -r requirements_inference.txt \
    && pip install --no-cache-dir --no-deps openai-whisper==20231117 \
       ffmpeg-python tiktoken more-itertools

ENV COSYVOICE_MODEL_DIR=/app/pretrained_models/CosyVoice2-0.5B
ENV HF_MODEL_ID=FunAudioLLM/CosyVoice2-0.5B
ENV USE_VLLM=0
ENV PORT=8001

VOLUME ["/app/pretrained_models"]
EXPOSE 8001

CMD ["python", "tts_stream_server.py"]
