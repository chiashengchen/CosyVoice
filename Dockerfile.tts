# CosyVoice2 TTS streaming server
# Serves POST /tts/stream → raw 16-bit PCM mono (visualllm pipeline contract)
#
# Weights are NOT baked in — downloaded from HuggingFace at first startup.
# Mount a volume at /app/pretrained_models to cache across restarts:
#   -v cosyvoice-weights:/app/pretrained_models
#
# Build:
#   docker build -f Dockerfile.tts -t cosyvoice-tts .
#
# Run (GPU required):
#   docker run --gpus all -p 8001:8001 \
#     -v cosyvoice-weights:/app/pretrained_models \
#     cosyvoice-tts

FROM nvidia/cuda:12.4.1-cudnn-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV LANG=C.UTF-8

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    git git-lfs curl wget ffmpeg sox libsox-dev build-essential \
    && git lfs install \
    && rm -rf /var/lib/apt/lists/*

# Miniforge (conda)
RUN wget -q https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-x86_64.sh -O /tmp/miniforge.sh \
    && bash /tmp/miniforge.sh -b -p /opt/conda \
    && rm /tmp/miniforge.sh
ENV PATH=/opt/conda/bin:$PATH

# Create cosyvoice env: python 3.10 + setuptools<72 (keeps pkg_resources) + pynini
RUN conda create -y -n cosyvoice python=3.10 "setuptools<72" pip wheel -c conda-forge \
    && conda install -y -n cosyvoice -c conda-forge pynini==2.1.5 \
    && conda clean -afy
ENV PATH=/opt/conda/envs/cosyvoice/bin:$PATH
ENV CONDA_DEFAULT_ENV=cosyvoice

WORKDIR /app

# Copy repo source (weights excluded via .dockerignore)
COPY . .

ENV PYTHONPATH="/app:/app/third_party/Matcha-TTS"

# Install Python deps
# - skip tensorrt: wheel_stub build backend unavailable; not needed (load_trt=False)
# - skip vllm pip package: CosyVoice's load_vllm connects to an external vllm server process,
#   not this package; USE_VLLM=0 uses standard PyTorch inference instead
# - pre-install numpy: pyworld's setup.py imports it before pip can satisfy the dep
RUN grep -vE 'tensorrt|^vllm' requirements.txt > /tmp/requirements_core.txt \
    && pip install --no-cache-dir numpy==1.26.4 \
    && pip install --no-cache-dir --no-build-isolation \
        -r /tmp/requirements_core.txt \
        huggingface_hub \
        librosa

# Weights are downloaded at runtime into this volume
VOLUME ["/app/pretrained_models"]

EXPOSE 8001

ENV COSYVOICE_MODEL_DIR=/app/pretrained_models/CosyVoice2-0.5B
ENV HF_MODEL_ID=FunAudioLLM/CosyVoice2-0.5B
ENV USE_VLLM=1
ENV COSYVOICE_VLLM_GPU_UTIL=0.5
ENV PORT=8001

CMD ["python", "tts_stream_server.py"]
